FRAPPE_BRANCH=version-15
NODE_MAJOR=18
BENCH_USER=ubuntu

# Runtime Bench. Keep this outside the Git repository so git pulls cannot
# replace production sites, logs, assets, or environment files.
BENCH_DIR=/home/ubuntu/frappe-bench

# OMC Frappe app source inside this repository. Update the repository prefix
# if the checkout is stored elsewhere on the server.
APP_SOURCE_DIR=/home/ubuntu/omc_deploy/omc_app/backend_omc_app/frappe-bench/apps/omc_app

# Set this before running site_setup.sh.
SITE_NAME=100.51.143.221
